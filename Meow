<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>For Anu 🌼</title>
<style>
body {
  margin: 0;
  font-family: 'Poppins', sans-serif;
  background: url('https://images.unsplash.com/photo-1529636798458-92182e662485') no-repeat center center/cover;
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}
.overlay {
  position: absolute;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
}
.container {
  background: rgba(255,255,255,0.95);
  padding: 25px;
  border-radius: 20px;
  text-align: center;
  z-index: 2;
  width: 90%;
  max-width: 400px;
}
button {
  padding: 10px 20px;
  margin: 8px;
  border: none;
  border-radius: 10px;
  cursor: pointer;
}
#yesBtn { background: green; color: white; }
#noBtn { background: red; color: white; position: absolute; }
.hidden { display: none; }.heart { position:absolute; animation: float 5s linear infinite; } @keyframes float { 0%{transform:translateY(100vh);} 100%{transform:translateY(-10vh);} }

.grid { display: grid; grid-template-columns: repeat(3, 60px); gap: 10px; justify-content: center; } .card { width:60px;height:60px;background:#ff4d6d;color:white; display:flex;align-items:center;justify-content:center; font-size:24px;border-radius:10px;cursor:pointer; } </style>

</head>
<body>
<div class="overlay"></div><div class="container">
<h2>Hey Anu 🌼</h2>
<p>You are my everything ❤️</p>
<p>Complete all games to unlock my proposal 🔐</p><!-- Game 1 --><div id="game1">
<p>🎯 Guess Number (1-5)</p>
<input id="g1" type="number" min="1" max="5">
<button onclick="checkG1()">Try</button>
<p id="g1r"></p>
</div><!-- Game 2 --><div id="game2" class="hidden">
<p>💖 Click 5 Hearts</p>
<button onclick="score++ ; upd()">💖</button>
<p id="sc">0/5</p>
</div><!-- Game 3 Memory --><div id="game3" class="hidden">
<p>🧠 Match Hearts</p>
<div class="grid" id="grid"></div>
<p id="g3r"></p>
</div><!-- Proposal --><div id="proposal" class="hidden">
<h2>Finally 💍</h2>
<p>Do you want to be mine forever?</p>
<button id="yesBtn" onclick="yes()">Yes ❤️</button>
<button id="noBtn" onmouseover="moveNo()">No 😜</button>
</div><div id="final" class="hidden">
<h2>❤️ I LOVE YOU ANU ❤️</h2>
<p>You made my life beautiful 😍</p>
</div>
</div><script>
let score=0;
function checkG1(){
 let n=Math.floor(Math.random()*5)+1;
 let g=document.getElementById('g1').value;
 if(g==n){
  document.getElementById('g1r').innerText='Correct 😍';
  document.getElementById('game2').classList.remove('hidden');
 } else {
  document.getElementById('g1r').innerText='Try again 😜';
 }
}

function upd(){
 score++;
 document.getElementById('sc').innerText=score+'/5';
 if(score>=5){
  document.getElementById('game3').classList.remove('hidden');
  createGrid();
 }
}

let first=null;
function createGrid(){
 let arr=['💖','💖','😍','😍','💘','💘'];
 arr.sort(()=>Math.random()-0.5);
 let grid=document.getElementById('grid');
 grid.innerHTML='';
 arr.forEach(val=>{
  let div=document.createElement('div');
  div.className='card';
  div.onclick=()=>{
    div.innerText=val;
    if(!first){first=div;}
    else{
      if(first.innerText==div.innerText){
        first=null;
      } else {
        setTimeout(()=>{first.innerText='';div.innerText='';first=null;},500);
      }
    }
  };
  grid.appendChild(div);
 });
 setTimeout(()=>{
  document.getElementById('proposal').classList.remove('hidden');
 },8000);
}

function moveNo(){
 let b=document.getElementById('noBtn');
 b.style.left=Math.random()*300+'px';
 b.style.top=Math.random()*300+'px';
}

function yes(){
 document.getElementById('final').classList.remove('hidden');
 startHearts();
}

function startHearts(){
 setInterval(()=>{
  let h=document.createElement('div');
  h.className='heart';
  h.innerText='💖';
  h.style.left=Math.random()*100+'vw';
  document.body.appendChild(h);
  setTimeout(()=>h.remove(),5000);
 },300);
}
</script></body>
</html>
